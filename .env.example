# Copy this file to .env and fill in your values
# CapRover: set these as environment variables in the app config

SECRET_KEY=your-secret-key-here
DEBUG=False
ALLOWED_HOSTS=yourdomain.caprover.com

# PostgreSQL (set up via CapRover one-click app)
DB_NAME=edu_phishing
DB_USER=postgres
DB_PASSWORD=your-db-password
DB_HOST=srv-captain--your-postgres-app
DB_PORT=5432

# Email (optional — defaults to console)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your@email.com
EMAIL_HOST_PASSWORD=your-app-password
